<Window x:Class="GameSaveReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameSaveReader"
        mc:Ignorable="d"
        Title="Game Save Value Reader" Height="300" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Game Name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Game:" VerticalAlignment="Center" Width="50"/>
            <ComboBox x:Name="GameNameComboBox" Width="350" IsEditable="True"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 1: Load Button -->
        <Button x:Name="LoadButton" Grid.Row="1" Content="Load Game Save"
                HorizontalAlignment="Left" Padding="16,6" Margin="0,0,0,16"
                Click="LoadButton_Click"/>

        <!-- Row 2: Results -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4"
                Padding="12">
            <TextBlock x:Name="ResultTextBlock" TextWrapping="Wrap"
                       VerticalAlignment="Center" FontSize="18"
                       Text="Load a game save to see the value."/>
        </Border>
    </Grid>
</Window>
