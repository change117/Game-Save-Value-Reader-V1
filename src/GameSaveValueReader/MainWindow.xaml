<Window x:Class="GameSaveValueReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Save Value Reader"
        Width="520" Height="320"
        MinWidth="400" MinHeight="260"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Game Name -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Game Name:"
                       Style="{StaticResource LabelStyle}"/>
            <TextBox   Grid.Column="1"
                       x:Name="GameNameBox"
                       Style="{StaticResource InputBox}"
                       Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Type the game name (e.g. Fable: The Lost Chapters)"/>
        </Grid>

        <!-- Row 1: Save File path (filled by file dialog) -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Save File:"
                       Style="{StaticResource LabelStyle}"/>
            <TextBox   Grid.Column="1"
                       Style="{StaticResource InputBox}"
                       Text="{Binding SaveFile, Mode=OneWay}"
                       IsReadOnly="True"
                       Background="#F5F5F5"
                       ToolTip="Path to the save file (set by Load Game Save button)"/>
        </Grid>

        <!-- Row 2: Load button -->
        <Button Grid.Row="2"
                Content="Load Game Save"
                HorizontalAlignment="Left"
                Padding="12,5"
                FontSize="13"
                Margin="0,0,0,12"
                Click="LoadSaveButton_Click"
                Command="{Binding LoadSaveCommand}"/>

        <!-- Row 3: Results -->
        <Border Grid.Row="3"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Result}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Padding="8"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
